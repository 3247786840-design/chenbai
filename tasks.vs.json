{
  "version": "0.2.1",
  "tasks": [
    {
      "taskName": "compile-lovingai (compile.ps1)",
      "appliesTo": "*",
      "type": "launch",
      "contextType": "build",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\compile.ps1"
      ]
    },
    {
      "taskName": "run start.cmd (一键启动)",
      "appliesTo": "*",
      "type": "default",
      "command": "${env.COMSPEC}",
      "args": [ "/c", "cd /d \"${workspaceRoot}\" && start.cmd" ]
    }
  ]
}
